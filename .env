PORT=8080
GIN_MODE=debug

DATABASE_URL=postgres://postgres:postgres@localhost:5432/usermgr?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# Token settings
TOKEN_LENGTH=32        # bytes of entropy → 64-char hex token
TOKEN_TTL=8h         # 30 days; set to 0 for non-expiring API keys
